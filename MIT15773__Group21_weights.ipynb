          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "df['cleaned_text'] = df['Text'].apply(lambda x: demoji.replace(x, \"\")) # without emoji\n",
        "df['replaced_text'] = df['Text'].apply(lambda x: demoji.replace_with_desc(x)) # textualised emoji\n",
        "df['Emoji'] =  df['Text'].apply(lambda x: list(demoji.findall(x).values()))\n",
        "\n",
        "## df['Likes'].min() -> 10.0, df['Likes'].max() -> 80.0\n",
        "df['Likes'] = df['Likes'].apply(lambda x: 'High' if x > 59 else 'Low')\n",
        "\n",
        "df = df[['Likes', 'cleaned_text', 'replaced_text', 'Emoji']]\n",
        "\n",
        "df.head()"
      ],
