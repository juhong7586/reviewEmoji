        "import shap\n",
        "\n",
        "def predict_fn(texts):\n",
        "    encoded = tokenizer(\n",
        "        list(texts),\n",
        "        max_length=41,\n",
        "        padding=\"max_length\",\n",
        "        truncation=True,\n",
        "        return_tensors=\"tf\"\n",
        "    )\n",
        "    probs = cleaned_best_model.predict({\n",
        "        \"input_ids\":      encoded[\"input_ids\"],\n",
        "        \"attention_mask\": encoded[\"attention_mask\"]\n",
        "    })\n",
        "    return probs  # shape (N, 1)\n",
        "\n",
        "explainer_C = shap.Explainer(\n",
        "    predict_fn,\n",
